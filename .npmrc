# Use the public npm registry explicitly. We do not use GitHub Packages.
# This also resolves a Dependabot npm error on GitHub-hosted repos: GitHub auto-injects its
# Packages registry (npm.pkg.github.com) into Dependabot, and the npm updater then requires an
# .npmrc (or scope/replaces-base config) before it will run. This file satisfies that.
registry=https://registry.npmjs.org/
